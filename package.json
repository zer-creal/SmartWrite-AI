{
  "name": "smartwrite-ai",
  "version": "0.1.0",
  "private": true,
  "description": "AI-powered smart document writer",
  "scripts": {
    "dev": "pnpm --filter @smartwrite/web dev",
    "build": "pnpm --filter @smartwrite/web build",
    "start": "pnpm --filter @smartwrite/web start",
    "lint": "pnpm --filter @smartwrite/web lint",
    "db:migrate": "pnpm --filter @smartwrite/db migrate",
    "db:generate": "pnpm --filter @smartwrite/db generate",
    "db:push": "pnpm --filter @smartwrite/db db:push",
    "db:studio": "pnpm --filter @smartwrite/db studio"
  },
  "devDependencies": {
    "typescript": "^5",
    "pnpm": "^8"
  }
}
